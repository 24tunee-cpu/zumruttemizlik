# ============================================
# GITIGNORE CONFIGURATION
# ============================================
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================
# DEPENDENCIES
# ============================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================
# BUILD OUTPUT
# ============================================
/.next/
/out/
/build
/dist

# ============================================
# TESTING & COVERAGE
# ============================================
/coverage
.nyc_output
*.lcov

# Playwright
/playwright-report/
/test-results/
/playwright/.cache/

# Jest
/jest-coverage/

# ============================================
# ENVIRONMENT FILES
# ============================================
# Local env files (never commit)
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# All env files (opt-in for committing if needed)
.env*

# ============================================
# IDE & EDITOR
# ============================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# Sublime
*.sublime-project
*.sublime-workspace

# ============================================
# OS FILES
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ============================================
# LOGS & DEBUG
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================
# CACHE
# ============================================
.eslintcache
.stylelintcache
.prettiercache
.cache/
.parcel-cache/

# ============================================
# MISCELLANEOUS
# ============================================
# Certificates
*.pem
*.cert
*.key

# Temporary files
*.tmp
*.temp
.tmp/

# ============================================
# DEPLOYMENT
# ============================================
.vercel
.netlify

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# GENERATED FILES
# ============================================
/src/generated/prisma

# ============================================
# LOCAL DATA
# ============================================
*.local
.local/

# Brand asset yedekleri (optimize script)
/public/logo.original.png
