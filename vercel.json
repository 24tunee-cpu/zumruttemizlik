{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/publish-blogs",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/maps-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/geo-sync",
      "schedule": "0 4 * * 1"
    }
  ],
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
