generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @map("userId") @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  /// İki adımlı doğrulama (TOTP) etkin — secret ayrı ortamda tutulmalıdır
  twoFactorEnabled Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  assignedContacts ContactRequest[] @relation("ContactAssignee")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  description String
  shortDesc   String
  image       String?
  icon        String   @default("Sparkles")
  features    String[]
  priceRange  String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model BlogPost {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  title                String
  slug                 String    @unique
  content              String
  excerpt              String
  image                String?
  category             String
  tags                 String[]
  author               String    @default("Zümrüt Vadi Temizlik")
  published            Boolean   @default(false)
  /// Yayın zamanı geldiğinde günlük cron `published` yapar
  scheduledPublishAt   DateTime?
  views                Int       @default(0)
  metaTitle            String?
  metaDesc             String?
  /// Zengin içerik blokları (Before/After, Video, FAQ, vb.) - JSON formatında
  richBlocks           Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([published, scheduledPublishAt])
  @@map("blogposts")
}

model ContactRequest {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String
  phone            String?
  service          String?
  message          String
  read             Boolean   @default(false)
  /// new | contacted | quoted | won | lost
  pipelineStatus   String    @default("new")
  internalNotes    String?
  reminderAt       DateTime?
  assignedUserId   String?   @db.ObjectId
  assignedUser     User?     @relation("ContactAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([pipelineStatus, createdAt])
  @@index([assignedUserId])
  @@map("contactrequests")
}

model Testimonial {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  location  String?
  rating    Int      @default(5)
  content   String
  avatar    String?
  service   String?
  /// Kanonik seed yorumları için anahtar (upsert); panelden eklenenlerde boş. MongoDB’de null unique olamadığı için @unique kullanılmaz.
  seedKey   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([seedKey])
  @@map("testimonials")
}

model Subscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("subscribers")
}

model SiteSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName        String   @default("Zümrüt Vadi Temizlik")
  siteDescription String?
  siteUrl         String   @default("https://www.zumrutvaditemizlik.com")
  logo            String?
  favicon         String   @default("/favicon.ico")
  primaryColor    String   @default("#10b981")
  secondaryColor  String   @default("#059669")
  accentColor     String   @default("#34d399")
  phone           String   @default("0551 925 09 43")
  email           String   @default("vedatgunenn@gmail.com")
  address         String?
  workingHours    String   @default("7/24 Hizmet")
  whatsapp        String?
  facebook        String?
  instagram       String?
  twitter         String?
  linkedin        String?
  youtube         String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  ogImage         String?
  twitterHandle   String?
  canonicalUrl    String?
  googleAnalyticsId String?
  googleTagManagerId String?
  facebookPixelId String?
  robotsTxt       String?
  sitemapEnabled  Boolean  @default(true)
  maintenanceMode Boolean  @default(false)
  customCss       String?
  customJs        String?
  /// { active, title, body, ctaLabel?, ctaHref?, dismissible? }
  promoBannerJson       Json?
  /// Kısa güven maddeleri metin dizisi
  trustBandItemsJson    Json?
  /// { whatsappFollowup, emailQuoteSubject, emailQuoteBody }
  messageTemplatesJson  Json?
  /// Pazarlama A/B: üst banner varyant anahtarı
  marketingBannerVariant String? @default("A")
  /// Çerez metni sürümü (banner tekrar göstermek için)
  consentPolicyVersion   String? @default("1")
  updatedAt       DateTime @updatedAt

  @@map("sitesettings")
}

model Gallery {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  /// Görsel URL (image veya video poster)
  image       String
  /// image | video
  mediaKind   String   @default("image")
  /// video embed veya doğrudan mp4 URL (Cloudinary vb.)
  videoUrl    String?
  category    String
  /// Medya kütüphanesi filtre etiketleri (virgülle ayrılmış veya tek etiket)
  tags        String[] @default([])
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("gallery")
}

model Certificate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  image       String
  issuer      String?
  date        DateTime?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("certificates")
}

model faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  answer    String
  category  String   @default("Genel")
  /// Kanonik seed SSS satırları için anahtar (upsert); panelden eklenenlerde boş.
  seedKey   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([seedKey])
  @@map("faq")
}

model Pricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceName String
  basePrice   Float
  pricePerSqm Float?
  unit        String   @default("m²")
  minPrice    Float?
  description String?
  features    String[]
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("pricing")
}

model TeamMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  role        String
  bio         String?
  image       String?
  phone       String?
  email       String?
  linkedin    String?
  /// Kanonik seed satırları için anahtar (upsert); panelden eklenenlerde boş.
  seedKey     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([seedKey])
  @@map("team_members")
}

model MarketingEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventType String
  source    String?
  linkUrl   String?
  linkText  String?
  pagePath  String?
  userAgent String?
  ipHash    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([source, createdAt])
  @@index([createdAt])
  @@map("marketing_events")
}

model ProgrammaticMetaOverride {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  district    String
  service     String
  title       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([district, service])
  @@index([isActive, updatedAt])
  @@map("programmatic_meta_overrides")
}

model SeoChecklistStatus {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique
  section     String
  label       String
  sortOrder   Int
  completed   Boolean   @default(false)
  completedAt DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([section, sortOrder])
  @@index([completed, updatedAt])
  @@map("seo_checklist_statuses")
}

model GscLandingMetric {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String
  pagePath    String
  date        DateTime
  clicks      Float    @default(0)
  impressions Float    @default(0)
  ctr         Float    @default(0)
  position    Float    @default(99)
  topQuery    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, date])
  @@index([date, impressions])
  @@map("gsc_landing_metrics")
}

model SeoAutomationSyncLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  source     String   @default("manual")
  status     String
  message    String?
  stats      Json?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([createdAt, status])
  @@map("seo_automation_sync_logs")
}

/// Google / Yandex / Apple harita ve işletme profili kayıtları (admin Haritalar modülü)
model MapPlatformListing {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  /// google | yandex | apple
  platform          String    @unique
  businessName      String?
  /// Haritada paylaşım veya arama URL’si
  listingUrl        String?
  /// İşletme yönetim paneli (GBP, Yandex, Apple Business Connect)
  dashboardUrl      String?
  /// Ek harita/embed veya alternatif görünüm URL’si
  mapsEmbedUrl      String?
  /// Google Place ID veya platformdaki benzeri tanımlayıcı
  externalPlaceId   String?
  /// not_connected | in_progress | connected
  connectionStatus  String    @default("not_connected")
  /// Checklist madde id → tamamlandı mı (client ile senkron)
  checklistState    Json?
  internalNotes     String?
  lastManualSyncAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("map_platform_listings")
}

/// Harita sağlayıcıları için OAuth (Google; Yandex/Apple sonrası)
model MapOAuthConnection {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  provider               String    @unique
  /// AES-256-GCM ile şifrelenmiş refresh token
  refreshTokenEnc        String
  accessToken            String?
  accessExpiresAt        DateTime?
  accountEmail           String?
  preferredAccountName   String?
  preferredLocationName  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("map_oauth_connections")
}

model MapSyncRun {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  provider   String
  source     String    @default("manual")
  status     String
  message    String?
  stats      Json?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([provider, startedAt])
  @@map("map_sync_runs")
}

/// API’den çekilen konum özeti
model MapLocationSnapshot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  provider       String
  resourceName   String
  title          String?
  payload        Json?
  fetchedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, resourceName])
  @@index([provider, fetchedAt])
  @@map("map_location_snapshots")
}

/// API’den çekilen yorumlar
model MapReviewSnapshot {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  provider             String
  reviewName           String   @unique
  locationResourceName String
  reviewerDisplayName  String?
  starRating           Int?
  comment              String?
  replyComment         String?
  reviewTime           String?
  payload              Json?
  fetchedAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([locationResourceName])
  @@index([provider, fetchedAt])
  @@map("map_review_snapshots")
}

/// Onay kuyruğu: taslak → onay → gönderim
model MapReviewReplyDraft {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  provider      String
  reviewName    String
  draftText     String
  /// pending | approved | sent | failed
  status        String    @default("pending")
  approvedAt    DateTime?
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([provider, reviewName])
  @@index([provider, status])
  @@map("map_review_reply_drafts")
}

/// Ücretsiz keşif / randevu talepleri (ön yüz formu)
model AppointmentRequest {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String
  phone          String?
  preferredDate  DateTime
  /// morning | afternoon | evening | flexible
  timeSlot       String    @default("flexible")
  district       String?
  address        String?
  serviceHint    String?
  notes          String?
  /// pending | confirmed | declined | done
  status         String    @default("pending")
  adminNotes     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, preferredDate])
  @@map("appointment_requests")
}

/// SEO ve eski URL yönetimi
model RedirectRule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fromPath  String   @unique
  toPath    String
  permanent Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redirect_rules")
}

/// Yönetici işlem kaydı
model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @db.ObjectId
  userEmail  String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([resource, createdAt])
  @@map("audit_logs")
}

enum Role {
  USER
  ADMIN
  EDITOR
}
